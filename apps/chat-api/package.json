{
	"name": "chat-api",
	"scripts": {
		"test": "bun test",
		"dev": "bun run build:daemon && bun run --hot src/index.ts",
		"build:daemon": "cd ../sandbox-daemon && bun run build",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts",
		"smoke:gateway": "bun run scripts/smoke-gateway.ts",
		"e2b:build:dev": "cd sandbox-template && bun run build.dev.ts",
		"e2b:build:prod": "cd sandbox-template && bun run build.prod.ts"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.1.5",
		"@mymemo/llm-token": "workspace:*",
		"@scalar/hono-api-reference": "^0.9.22",
		"drizzle-orm": "^0.45.2",
		"e2b": "^2.14.0",
		"hono": "^4.10.1",
		"hono-openapi": "^1.1.0",
		"hono-pino": "^0.10.3",
		"pino": "^9.14.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@electric-sql/pglite": "^0.5.3",
		"@types/bun": "^1.3.11",
		"drizzle-kit": "^0.31.10"
	}
}
