# gateway secrets for the local E2E harness (compose.yaml). Copy to
#   apps/gateway/.env
# DATABASE_URL / DB_SSL / GATEWAY_PORT are set inline in compose.yaml (local-only
# dev DB), so only secrets go here.

# Real Anthropic provider key — lives ONLY in the gateway, injected on proxied
# /v1/messages calls. The sandbox never sees it.
ANTHROPIC_API_KEY=sk-ant-...

# HMAC secret for per-turn tokens (gateway verifies what chat-api mints).
# MUST match apps/chat-api/.env's LLM_TOKEN_SECRET.
LLM_TOKEN_SECRET=local-dev-llm-token-secret-change-me
