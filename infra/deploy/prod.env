# Checked-in CI/deploy configuration for the production-like agent deploy.
# Terraform-owned infrastructure inputs live in infra/terraform/prod.tfvars.
# Keep actual credential material in AWS Secrets Manager.

AWS_REGION=us-west-2
DEPLOY_ENVIRONMENT=prod

# Smoke-test inputs. This is the base URL the GitHub Actions runner calls after
# deploy, for example the agent-owned ALB DNS route that forwards to chat-api. It is
# not the same as gateway_public_url in prod.tfvars, which is runtime config
# used by chat-api/E2B to call the agent gateway for LLM/doc access.
# Leave as REPLACE_ME until the agent route is reachable from GitHub Actions.
AGENT_SMOKE_BASE_URL=REPLACE_ME_AGENT_SMOKE_BASE_URL
AGENT_SMOKE_MEMBER_CODE=codex-smoke
AGENT_SMOKE_PARTNER_CODE=mymemo
AGENT_SMOKE_EXPECT_GATE_CLOSED=true
