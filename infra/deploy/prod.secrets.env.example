# Copy to infra/deploy/prod.secrets.env. The copied file is git-ignored.
# These are literal secret values used only to create/update AWS Secrets Manager
# entries. Do not commit the copied file.
#
# Format is simple KEY=value dotenv. The deploy script parses this file as data,
# not shell, so $VARIABLES and command substitutions are not expanded.

LLM_TOKEN_SECRET_VALUE=
STATSIG_SERVER_SECRET_VALUE=
OPENROUTER_API_KEY_VALUE=
E2B_API_KEY_VALUE=

# Optional. KB_DATABASE_URL is currently bootstrapped by
# scripts/deploy/create_bootstrap_kb_database_secret.sh from mymemo-service.
# Set this only when replacing that bootstrap with a proper read-only KB URL.
KB_DATABASE_URL_VALUE=
