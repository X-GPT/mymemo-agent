# Local E2E harness secrets (MYM-31). Copy to `.env` (gitignored) and fill in:
#   cp .env.example .env
# compose.yaml interpolates these so the same shared secrets reach every service.

# Real Anthropic provider key — lives ONLY in the gateway, injected on proxied
# /v1/messages calls. The sandbox never sees it.
ANTHROPIC_API_KEY=sk-ant-...

# HMAC secret for per-turn LLM/document tokens. MUST be identical for chat-api
# (mints) and gateway (verifies). Any long random string works locally.
LLM_TOKEN_SECRET=local-dev-llm-token-secret-change-me

# Shared bearer for the daemon's /turn endpoint. MUST match between chat-api and
# the sandbox container.
DAEMON_AUTH_TOKEN=local-dev-daemon-auth-token-change-me

# Postgres (the local KB). Defaults are baked into compose.yaml; override here if
# you like. POSTGRES_PASSWORD also feeds the gateway's DATABASE_URL.
# POSTGRES_USER=mymemo
# POSTGRES_PASSWORD=mymemo
# POSTGRES_DB=mymemo_kb

# chat-api log level (info|debug|warn|error)
# LOG_LEVEL=info
